<?xml version="1.0" encoding="UTF-8"?>

<odoo>
    <record model="ir.ui.view" id="product_length_wizard_form_view">
        <field name="name">product.length.wizard.form.view</field>
        <field name="model">product.length.wizard</field>
        <field name="arch" type="xml">
            <form string="Enter the desired length">
                <group>
                    <field name="length"/>
                </group>
                <footer>
                    <button name="assign_length" type="object" string="Next" class="oe_highlight"/>
                </footer>
            </form>
        </field>
    </record>

    <act_window id="launch_product_length_wizard"
                name="Assign Length"
                src_model="sale.order.line"
                res_model="product.length.wizard"
                view_mode="form"
                target="new"/>
</odoo>